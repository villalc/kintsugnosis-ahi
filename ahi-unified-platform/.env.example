# Firebase Configuration for AHI Unified Platform
# Copy this file to .env.local and fill in the values

# Firebase Client SDK
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your-measurement-id

# Security & App Check
# Required for "The Eye" dashboard access
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-v3-site-key

# Telemetry Endpoints
# Optional: URL for the Cloud Function. If not set, defaults to legacy API (localhost:8000)
NEXT_PUBLIC_GEOMETRY_FN_URL=https://region-project.cloudfunctions.net/audit-ricci

# Stripe Configuration
# Publishable key (safe for client-side)
NEXT_PUBLIC_STRIPE_PK=pk_live_your-stripe-publishable-key

# Stripe Buy Button IDs (from Stripe Dashboard > Payment Links > Buy Buttons)
NEXT_PUBLIC_STRIPE_BTN_QUICK=buy_btn_xxx
NEXT_PUBLIC_STRIPE_BTN_TECHNICAL=buy_btn_xxx
NEXT_PUBLIC_STRIPE_BTN_ENTERPRISE=buy_btn_xxx

# Stripe Payment Link (legacy, optional)
NEXT_PUBLIC_STRIPE_AUDIT_LINK=https://buy.stripe.com/test_example123
